# Copy to .env and set your own values. .env is gitignored — never commit it.

# Flask session secret. REQUIRED — the app fails to start if this is unset.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Local intel-pipeline reports directory.
INTEL_REPORTS_PATH=~/Documents/Projects/intel-pipeline/reports

# Obsidian inbox directory.
INTEL_OBSIDIAN_PATH=~/Documents/MyVault/Inbox

# intel-pipeline root — used to locate config/sources.yaml for source status.
INTEL_PIPELINE_PATH=~/Documents/Projects/intel-pipeline
